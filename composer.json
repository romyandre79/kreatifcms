{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "bacon/bacon-qr-code": "*",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "nwidart/laravel-modules": "^12.0",
        "pragmarx/google2fa-laravel": "*",
        "predis/predis": "^3.4",
        "tightenco/ziggy": "^2.0",
        "tymon/jwt-auth": "^2.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\ImageConverter\\": "Modules/ImageConverter/app/",
            "Modules\\Security\\": "Modules/Security/app/",
            "Modules\\ReusableBlock\\": "Modules/ReusableBlock/app/",
            "Modules\\Seo\\": "Modules/Seo/app/",
            "Modules\\Slideshow\\": "Modules/Slideshow/app/",
            "Modules\\SocialMediaBlock\\": "Modules/SocialMediaBlock/app/",
            "Modules\\TimelineBlock\\": "Modules/TimelineBlock/app/",
            "Modules\\Navbar\\": "Modules/Navbar/app/",
            "Modules\\Hero\\": "Modules/Hero/app/",
            "Modules\\TextBlock\\": "Modules/TextBlock/app/",
            "Modules\\ImageBlock\\": "Modules/ImageBlock/app/",
            "Modules\\FeatureGrid\\": "Modules/FeatureGrid/app/",
            "Modules\\ContentList\\": "Modules/ContentList/app/",
            "Modules\\DatabaseManager\\": "Modules/DatabaseManager/app/",
            "Modules\\RedisCache\\": "Modules/RedisCache/app/",
            "Modules\\EmailConfig\\": "Modules/EmailConfig/app/",
            "Modules\\EmailTemplates\\": "Modules/EmailTemplates/app/",
            "Modules\\EditorSummernote\\": "Modules/EditorSummernote/app/",
            "Modules\\Captcha\\": "Modules/Captcha/app/",
            "Modules\\AiAssistant\\": "Modules/AiAssistant/app/",
            "Modules\\OtpService\\": "Modules/OtpService/app/",
            "Modules\\JobManager\\": "Modules/JobManager/app/",
            "Modules\\MediaLibrary\\": "Modules/MediaLibrary/app/",
            "Modules\\FormBlock\\": "Modules/FormBlock/app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\CorporateTheme\\": "Modules/CorporateTheme/app/",
            "Modules\\Layout\\": "Modules/Layout/app/",
            "Modules\\ContentType\\": "Modules/ContentType/app/",
            "Modules\\PhpEventHooks\\": "Modules/PhpEventHooks/app/",
            "Modules\\MegaMenu\\": "Modules/MegaMenu/app/",
            "Modules\\TwoFactorAuth\\": "Modules/TwoFactorAuth/app/",
            "Modules\\GeneralApi\\": "Modules/GeneralApi/app/",
            "Modules\\VideoBlock\\": "Modules/VideoBlock/app/",
            "Modules\\VideoGrid\\": "Modules/VideoGrid/app/",
            "Modules\\Brevo\\": "Modules/Brevo/app/",
            "Modules\\PhotoGrid\\": "Modules/PhotoGrid/app/",
            "Modules\\DataGrid\\": "Modules/DataGrid/app/",
            "Modules\\LanguageSwitcher\\": "Modules/LanguageSwitcher/app/"
        }

    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
